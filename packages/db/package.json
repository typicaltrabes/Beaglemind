{
  "name": "@beagle-console/db",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.7",
    "@aws-sdk/client-s3": "3.1033.0"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "tsx": "latest"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schema/auth-schema": {
      "import": "./src/schema/auth-schema.ts",
      "types": "./src/schema/auth-schema.ts"
    }
  }
}
